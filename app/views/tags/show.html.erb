<h1>Posts tagged with "<%= @tag.name %>"</h1>

<% if @posts.any? %>
  <ul>
    <% @posts.each do |post| %>
      <li>
        <h3><%= link_to post.title, post_path(post) %></h3>
        <p>By <%= post.user.username %></p>
        <p><%= truncate(post.body, length: 120) %></p>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No posts found for this tag.</p>
<% end %>