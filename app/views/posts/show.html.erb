<h1><%= @post.title %></h1>

<p><strong>Author:</strong> <%= @post.user.username %></p>
<p><%= simple_format(@post.body) %></p>

<% if @post.tags.any? %>
  <p>
    <strong>Tags:</strong>
    <% @post.tags.each do |tag| %>
      <%= link_to tag.name, tag_path(tag) %>
    <% end %>
  </p>
<% end %>

<% if logged_in? && current_user == @post.user %>
  <%= link_to "Edit", edit_post_path(@post) %> |
  <%= button_to "Delete", post_path(@post), method: :delete, data: { turbo_confirm: "Are you sure?" } %>
<% end %>

<hr>

<h2>Comments</h2>

<% if @post.comments.any? %>
  <% @post.comments.each do |comment| %>
    <div>
      <p>
        <strong><%= comment.user.username %>:</strong>
        <%= comment.content %>
      </p>

      <% if logged_in? && current_user == comment.user %>
        <%= button_to "Delete Comment",
              post_comment_path(@post, comment),
              method: :delete,
              data: { turbo_confirm: "Delete this comment?" } %>
      <% end %>
    </div>
    <hr>
  <% end %>
<% else %>
  <p>No comments yet.</p>
<% end %>

<% if logged_in? %>
  <h3>Add a Comment</h3>

  <%= form_with model: [@post, @comment], local: true do |form| %>
    <div>
      <%= form.label :content %><br>
      <%= form.text_area :content, rows: 4 %>
    </div>

    <div>
      <%= form.submit "Post Comment" %>
    </div>
  <% end %>
<% else %>
  <p><%= link_to "Login", login_path %> to leave a comment.</p>
<% end %>