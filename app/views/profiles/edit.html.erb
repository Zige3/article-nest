<h1>Edit Profile</h1>

<% if @profile.errors.any? %>
  <div>
    <h3><%= pluralize(@profile.errors.count, "error") %> prevented this profile from being saved:</h3>
    <ul>
      <% @profile.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @profile, url: profile_path, local: true do |form| %>
  <div>
    <%= form.label :display_name %><br>
    <%= form.text_field :display_name %>
  </div>

  <div>
    <%= form.label :bio %><br>
    <%= form.text_area :bio, rows: 5 %>
  </div>

  <div>
    <%= form.submit "Update Profile" %>
  </div>
<% end %>